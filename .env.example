# This file documents LOCAL development values. On Vercel, DATABASE_URL and
# TOKEN_ENCRYPTION_KEY must be set PER ENVIRONMENT SCOPE (Production vs Preview) so that
# preview deployments never migrate the production database. Point Preview's DATABASE_URL at
# a separate (shared) Neon `preview` branch. See README "Environments".

# Database connection (Neon cloud URL in production, not needed for local dev)
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require
# For local dev:
#DATABASE_URL=postgresql://postgres:postgres@localhost:4444/main?sslmode=require


# Session signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_random_secret_here

# AES-256-GCM key for encrypting Garmin OAuth tokens at rest (64 hex chars / 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set per Vercel environment scope (a separate value for Production and Preview) before
# deploying the token-encryption migration.
TOKEN_ENCRYPTION_KEY=your_64_hex_char_key_here

# Set to "development" for local dev (uses Docker Postgres + neon-proxy)
NODE_ENV=development

# Set to resend.com api key
RESEND_API_KEY=re_your_personal_test_key

# Set to the email address you want to send from
RESEND_FROM_EMAIL=email@step-tracker.com

# The URL of your app (to link to from emails)
APP_URL=http://step-tracker.com
